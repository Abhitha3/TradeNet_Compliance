@model TradeNet11.Models.ViewModels.CaseDetailViewModel

<h5>@Model.Case.BusinessName — @Model.Case.LicenseNumber</h5>
<hr />

<div class="row mb-3">
    <div class="col-md-6">
        <strong>Issue Type:</strong> @Model.Case.IssueType<br />
        <strong>Severity:</strong> @Model.Case.Severity<br />
        <strong>Status:</strong> @Model.Case.Status
    </div>
    <div class="col-md-6">
        <strong>Reported:</strong> @Model.Case.ReportedAt.ToString("g")<br />
        <strong>Resolved:</strong> @(Model.Case.ResolvedAt?.ToString("g") ?? "—")<br />
        <strong>Assigned Officer:</strong> @(Model.Case.AssignedOfficer?.FullName ?? "Unassigned")
    </div>
</div>

<p><strong>Description:</strong><br />@Model.Case.Description</p>

<!-- Compliance Records / History -->
<h6 class="mt-4">Compliance History</h6>
@if (Model.Records.Any())
{
    <table class="table table-sm table-bordered">
        <thead class="table-light">
            <tr>
                <th>Action</th>
                <th>Details</th>
                <th>Officer Remarks</th>
                <th>Rule Violation</th>
                <th>Timestamp</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model.Records)
            {
                <tr>
                    <td>@r.ActionTaken</td>
                    <td>@r.Details</td>
                    <td>@(r.OfficerRemarks ?? "—")</td>
                    <td>@(r.RuleViolation ?? "—")</td>
                    <td>@r.Timestamp.ToString("g")</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">No history records yet.</p>
}

<!-- Actions -->
<h6 class="mt-4">Update Status</h6>
<form asp-controller="ComplianceDashboard" asp-action="UpdateStatus" method="post">
    <input type="hidden" name="caseId" value="@Model.Case.Id" />
    <div class="row g-2 align-items-end">
        <div class="col-md-4">
            <label class="form-label">New Status</label>
            <select name="newStatus" class="form-select">
                <option value="Investigating">Investigating</option>
                <option value="Compliant">Mark Compliant</option>
                <option value="NonCompliant">Mark Non-Compliant</option>
                <option value="DocumentsRequested">Request Documents</option>
                <option value="AuditStarted">Start Audit</option>
            </select>
        </div>
        <div class="col-md-5">
            <label class="form-label">Remarks</label>
            <input type="text" name="remarks" class="form-control" placeholder="Optional remarks" />
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-primary w-100">Update</button>
        </div>
    </div>
</form>
