@model TradeNet11.Models.Audit
@{
    ViewData["Title"] = "Create Audit";
}

<h2 class="mb-4">Create New Audit</h2>

<div class="card shadow">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div class="mb-3">
                <label asp-for="AuditTitle" class="form-label">Audit Title</label>
                <input asp-for="AuditTitle" class="form-control" required />
            </div>
            <div class="mb-3">
                <label asp-for="BusinessName" class="form-label">Business Name</label>
                <input asp-for="BusinessName" class="form-control" required />
            </div>
            <div class="mb-3">
                <label asp-for="ScheduledDate" class="form-label">Scheduled Date</label>
                <input asp-for="ScheduledDate" type="date" class="form-control" required />
            </div>
            <div class="mb-3">
                <label asp-for="ComplianceCaseId" class="form-label">Related Case ID (optional)</label>
                <input asp-for="ComplianceCaseId" type="number" class="form-control" />
            </div>
            <button type="submit" class="btn btn-success">Create Audit</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
