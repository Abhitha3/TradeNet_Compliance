@model IEnumerable<TradeNet11.Models.ProgramCompliance>
@{
    ViewData["Title"] = "Program & Subsidy Compliance";
}

<h2 class="mb-4"><i class="bi bi-cash-stack"></i> Program &amp; Subsidy Compliance</h2>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Program</th>
                <th>Business</th>
                <th>Eligibility</th>
                <th>Misuse Flag</th>
                <th>Fund Usage</th>
                <th>Reviewed</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                var eligBadge = p.EligibilityStatus switch
                {
                    "Eligible" => "bg-success",
                    "NotEligible" => "bg-danger",
                    _ => "bg-secondary"
                };

                <tr>
                    <td>@p.Id</td>
                    <td>@p.ProgramName</td>
                    <td>@p.BusinessName</td>
                    <td><span class="badge @eligBadge">@p.EligibilityStatus</span></td>
                    <td>
                        @if (p.IsMisuseFlag)
                        {
                            <span class="badge bg-danger">⚠ Misuse</span>
                        }
                        else
                        {
                            <span class="text-muted">None</span>
                        }
                    </td>
                    <td>@p.FundUsageSummary</td>
                    <td>@p.ReviewedAt.ToString("d")</td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary"
                                data-bs-toggle="modal"
                                data-bs-target="#updateModal-@p.Id">
                            Update
                        </button>
                    </td>
                </tr>

                <!-- Update Modal -->
                <div class="modal fade" id="updateModal-@p.Id" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <form asp-action="UpdateEligibility" method="post">
                                <input type="hidden" name="id" value="@p.Id" />
                                <div class="modal-header">
                                    <h5 class="modal-title">Update: @p.ProgramName</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body">
                                    <div class="mb-3">
                                        <label class="form-label">Eligibility Status</label>
                                        <select name="eligibilityStatus" class="form-select">
                                            <option value="Pending" selected="@(p.EligibilityStatus == "Pending")">Pending</option>
                                            <option value="Eligible" selected="@(p.EligibilityStatus == "Eligible")">Eligible</option>
                                            <option value="NotEligible" selected="@(p.EligibilityStatus == "NotEligible")">Not Eligible</option>
                                        </select>
                                    </div>
                                    <div class="form-check mb-3">
                                        <input type="checkbox" name="isMisuseFlag" value="true" class="form-check-input"
                                               @(p.IsMisuseFlag ? "checked" : "") />
                                        <label class="form-check-label">Raise Misuse Flag</label>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Remarks</label>
                                        <textarea name="remarks" class="form-control" rows="3">@p.Remarks</textarea>
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                    <button type="submit" class="btn btn-primary">Save Changes</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </tbody>
    </table>
</div>
