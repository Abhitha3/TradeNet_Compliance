@model IEnumerable<TradeNet11.Models.ProgramCompliance>
@{
    ViewData["Title"] = "Program & Subsidy Compliance";
}

<h2 class="page-title"><i class="bi bi-cash-stack"></i> Program &amp; Subsidy Compliance</h2>

<div class="section">
    <table class="tn-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Title</th>
                <th>Business</th>
                <th>Eligibility</th>
                <th>Usage</th>
                <th>Misuse</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr class="empty-row"><td colspan="8">No programs available.</td></tr>
            }
            @foreach (var p in Model)
            {
                var eligCls = p.EligibilityStatus switch { "Eligible" => "st-eligible", "NotEligible" => "st-noteligible", _ => "st-pending" };

                <tr>
                    <td>@p.Id</td>
                    <td>@p.ProgramName</td>
                    <td>@p.BusinessName</td>
                    <td><span class="st @eligCls">@p.EligibilityStatus</span></td>
                    <td style="font-size:12px">@p.FundUsageSummary</td>
                    <td>
                        @if (p.IsMisuseFlag)
                        {
                            <span class="flag-misuse"><i class="bi bi-exclamation-triangle"></i> Misuse</span>
                        }
                        else
                        {
                            <span style="color:var(--muted);font-size:12px">None</span>
                        }
                    </td>
                    <td style="font-size:12px;color:var(--muted)">@p.ReviewedAt.ToString("d")</td>
                    <td>
                        <button class="btn-tn btn-accent"
                                data-bs-toggle="modal"
                                data-bs-target="#updateModal-@p.Id">
                            Update
                        </button>
                    </td>
                </tr>

                <!-- Update Modal -->
                <div class="modal fade" id="updateModal-@p.Id" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <form asp-action="UpdateEligibility" method="post">
                                <input type="hidden" name="id" value="@p.Id" />
                                <div class="modal-header modal-header-blue">
                                    <h5 class="modal-title">Update: @p.ProgramName</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body">
                                    <div class="mb-3">
                                        <label class="form-label" style="font-size:13px;color:var(--muted)">Eligibility Status</label>
                                        <select name="eligibilityStatus" class="form-select">
                                            <option value="Pending" selected="@(p.EligibilityStatus == "Pending")">Pending</option>
                                            <option value="Eligible" selected="@(p.EligibilityStatus == "Eligible")">Eligible</option>
                                            <option value="NotEligible" selected="@(p.EligibilityStatus == "NotEligible")">Not Eligible</option>
                                        </select>
                                    </div>
                                    <div class="form-check mb-3">
                                        <input type="checkbox" name="isMisuseFlag" value="true" class="form-check-input"
                                               @(p.IsMisuseFlag ? "checked" : "") />
                                        <label class="form-check-label">Raise Misuse Flag</label>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label" style="font-size:13px;color:var(--muted)">Remarks</label>
                                        <textarea name="remarks" class="form-control" rows="3">@p.Remarks</textarea>
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn-tn btn-ghost-tn" data-bs-dismiss="modal">Close</button>
                                    <button type="submit" class="btn-tn btn-accent">Save Changes</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </tbody>
    </table>
</div>
